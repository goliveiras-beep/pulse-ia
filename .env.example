# Copie este arquivo para .env.local e preencha os valores
# Na Vercel, adicione essas variáveis em Settings > Environment Variables

# Token do bot do Slack (começa com xoxb-)
# Encontra em: api.slack.com/apps > seu app > Install App > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-SEU-TOKEN-AQUI

# API Key da Anthropic (Claude)
# Cria em: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-SEU-TOKEN-AQUI
